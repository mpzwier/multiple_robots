<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">

    <!-- Main recovery wrapper -->
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">

      <!-- Replan only when goal is updated -->
      <PipelineSequence name="NavigateOnGoalUpdate">

        <!-- Default planner for far paths -->
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>

        <!-- Only compute path when the goal changes -->
        <GoalUpdatedController>
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}"/>
            <Sequence>
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
          </RecoveryNode>
        </GoalUpdatedController>

        <!-- Follow path with controller + planner switching and hysteresis -->
        <RecoveryNode number_of_retries="1" name="FollowPathSelector">
          <ReactiveFallback name="ControllerAndPlannerSelector">

            <!-- Short path → OmniController (MPPI) + SmacPlannerHybrid -->
            <Sequence name="ShortDistanceLogic">
              <IsGoalNearby path="{path}" proximity_threshold="1.0" robot_base_frame="base_footprint"/>
              <PlannerSelector selected_planner="{selected_planner}" default_planner="SmacPlannerHybrid" topic_name="planner_selector"/>
              <FollowPath path="{path}" controller_id="OmniController" error_code_id="{follow_path_error_code}"/>
            </Sequence>

            <!-- Long path → FollowPath (RPP) + GridBased -->
            <Sequence name="LongDistanceLogic">
              <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>
              <FollowPath path="{path}" controller_id="StandardController" error_code_id="{follow_path_error_code}"/>
            </Sequence>

          </ReactiveFallback>

          <!-- Local controller recovery -->
          <Sequence>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>

        </RecoveryNode>

      </PipelineSequence>

      <!-- Global recovery fallback -->
      <Sequence>
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>
        <ReactiveFallback name="RecoveryFallback">
          <GoalUpdated/>
          <RoundRobin name="RecoveryActions">
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <Spin spin_dist="1.57" error_code_id="{spin_error_code}"/>
            <Wait wait_duration="5.0"/>
            <BackUp backup_dist="0.30" backup_speed="0.15" error_code_id="{backup_code_id}"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>

    </RecoveryNode>

  </BehaviorTree>
</root>